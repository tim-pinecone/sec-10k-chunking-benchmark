# AWS
AWS_PROFILE=your-sso-profile
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket

# EC2 instance type — g4dn.xlarge (T4 GPU) recommended for NeuralChunker / LateChunker
# c5.2xlarge is sufficient for CPU-only chunkers (RecursiveChunker, SentenceChunker)
INSTANCE_TYPE=g4dn.xlarge

# Optional: SSH key for direct EC2 access (if not set, SSM is used)
# KEY_NAME=your-key-pair-name

# OpenAI — required for openai:text-embedding-ada-002 and openai:text-embedding-3-large
OPENAI_API_KEY=sk-...

# HuggingFace — required for upload_to_hf.py and upload_embeddings_to_hf.py
HF_TOKEN=hf_...

# Benchmark arguments passed directly to benchmark.py
# Example: --embedding-model openai:text-embedding-ada-002 --configs RecursiveChunker:512,RecursiveChunker:1024 --run-name my-run
BENCHMARK_ARGS=
